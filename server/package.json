{
  "name": "novelhelper-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "novelhelper 后端 — 最小 LLM 网关（Provider 抽象层起点，无状态）",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --outfile=dist/server.bundle.js --external:better-sqlite3 --external:sqlite-vec --external:napi-* --format=esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "fastify": "^5.2.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
